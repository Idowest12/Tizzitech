rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    
    // FIXED: Strict admin check checking the exact authenticated email
    function isAdmin() { 
       return isSignedIn() && request.auth.token.email == 'idowutosin70@gmail.com'; 
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'brand', 'price', 'stock'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.category is string && data.category.size() <= 100
        && data.brand is string && data.brand.size() <= 100
        && data.price is number
        && data.stock is number
        && data.get('costPrice', 0) is number
        && data.get('condition', '') is string
        && data.get('imageUrl', '') is string
        && data.get('description', '') is string;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isValidId(productId) && isValidProduct(incoming()) && (
        isAdmin() || 
        // Allow unauthenticated clients to decrement stock during checkout
        (incoming().diff(existing()).affectedKeys().hasOnly(['stock'])
          && incoming().stock < existing().stock
          && incoming().stock >= 0)
      );
      allow delete: if isAdmin() && isValidId(productId);
    }
    
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'items', 'total', 'status', 'orderDate'])
        && data.id is string && data.id.size() <= 128
        && data.items is list
        && data.total is number
        && data.status is string && data.status in ['Pending', 'Confirmed', 'Processing', 'Picked Up', 'Delivered', 'Cancelled', 'Accepted', 'In Transit']
        && data.orderDate is string && data.orderDate.size() <= 50;
    }

    match /orders/{orderId} {
      // Anyone can create an order during checkout
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      // ANYONE can read a specific order if they have the exact ID (for the tracking page)
      // but ONLY admins can list all orders.
      allow get: if true;
      allow list: if isAdmin();
      // Only admins can update the status of the order (or delete it)
      allow update, delete: if isAdmin();
    }
    
    match /settings/{settingId} {
      // Settings like delivery zones are readable by the frontend, but only editable by Admin
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /newsletter_campaigns/{campaignId} {
      // Only admins can manage newsletter campaigns
      allow read, write: if isAdmin();
    }

    match /newsletter_subscribers/{subscriberId} {
      // Anyone can subscribe, but only admins can view the list of subscribers
      allow create: if true;
      allow get, list, update, delete: if isAdmin();
    }


    function isValidAuditLog(data) {
      return data.keys().hasAll(['id', 'timestamp', 'action', 'details', 'email', 'ip', 'userAgent'])
        && data.id is string
        && data.timestamp is number
        && data.action is string
        && data.details is string
        && data.email is string
        && data.ip is string
        && data.userAgent is string;
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      // Allow creation by anyone (since login attempts can be from unauthenticated users),
      // but enforce strict schema validation to prevent abuse.
      allow create: if isValidAuditLog(incoming());
    }

    match /admin_otps/{docId} {
      allow get, create, update, delete: if true;
      allow list: if false;
    }
    match /admin_sessions/{docId} {
      allow get, create, update, delete: if true;
      allow list: if false;
    }
    match /admins/{adminId} { {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin() && isValidId(adminId);
    }
  }
}
