rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
        (request.auth != null || exists(/databases/$(database)/documents/admins/$(request.auth.uid))); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'brand', 'price', 'stock'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.category is string && data.category.size() <= 100
        && data.brand is string && data.brand.size() <= 100
        && data.price is number
        && data.stock is number
        && data.get('costPrice', 0) is number
        && data.get('condition', '') is string
        && data.get('imageUrl', '') is string
        && data.get('description', '') is string;
    }
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isValidId(productId) && isValidProduct(incoming()) && (
        isAdmin() || 
        (incoming().diff(existing()).affectedKeys().hasOnly(['stock'])
          && incoming().stock < existing().stock
          && incoming().stock >= 0)
      );
      allow delete: if isAdmin() && isValidId(productId);
    }
    
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'items', 'total', 'status', 'orderDate'])
        && data.id is string && data.id.size() <= 128
        && data.items is list
        && data.total is number
        && data.status is string && data.status in ['Pending', 'Confirmed', 'Processing', 'Picked Up', 'Delivered', 'Cancelled', 'Accepted', 'In Transit']
        && data.orderDate is string && data.orderDate.size() <= 50;
    }
    match /orders/{orderId} {
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow read: if true;
      allow update: if isValidId(orderId) && isValidOrder(incoming());
      allow delete: if isAdmin() && isValidId(orderId);
    }
    
    function isValidSettings(data) {
      return data.get('categories', []) is list 
          && data.get('brands', []) is list
          && data.get('deliveryZones', []) is list;
    }
    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(settingId) && isValidSettings(incoming());
    }
    
    match /newsletter_campaigns/{campaignId} {
      allow read, write: if true;
    }
    match /newsletter_subscribers/{subscriberId} {
      allow read, write: if true;
    }
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin() && isValidId(adminId);
    }
  }
}
