{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A tech product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "condition": { "type": "string" },
        "specs": { "type": "object" },
        "stock": { "type": "number" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "category", "brand", "price", "condition", "stock", "imageUrl"]
    },
    "Order": {
      "title": "Order",
      "description": "A user's order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "role", "createdAt"]
    }
  },
  "firestore": {
    "products": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store inventory"
    },
    "orders": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders placed by users"
    },
    "users": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    }
  }
}
