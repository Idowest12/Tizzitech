{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product for sale in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "costPrice": { "type": "number" },
        "condition": { "type": "string" },
        "stock": { "type": "number" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "category", "brand", "price", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Processing", "Picked Up", "Delivered", "Cancelled"] },
        "orderDate": { "type": "string" },
        "customerInfo": { "type": "object" }
      },
      "required": ["id", "items", "total", "status", "orderDate"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global store settings like categories and brands.",
      "type": "object",
      "properties": {
        "categories": { "type": "array" },
        "brands": { "type": "array" },
        "deliveryZones": { "type": "array" }
      }
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products available in the store."
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders."
    },
    "settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Store settings (e.g., globals)."
    }
  }
}
